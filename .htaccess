# ============================================================
# PW Portal - Security Configuration (.htaccess)
# ============================================================

# Disable directory listing
Options -Indexes

# Protect data directory
<IfModule mod_rewrite.c>
  RewriteEngine On

  # Block access to data directory entirely
  RewriteRule ^data/ - [F,L]

  # Block direct access to API files without AJAX header
  # (actual check is done in PHP for reliability)

  # Force HTTPS (uncomment if SSL is available)
  # RewriteCond %{HTTPS} off
  # RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
</IfModule>

# Block access to sensitive files
<FilesMatch "\.(json|log|txt|bak|sql|env|py|sh|config)$">
  Require all denied
</FilesMatch>

# Security Headers
<IfModule mod_headers.c>
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "DENY"
  Header always set X-XSS-Protection "1; mode=block"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "geolocation=(), microphone=(), camera=()"
  # Remove PHP version exposure
  Header unset X-Powered-By
</IfModule>

# Prevent PHP errors from showing
php_flag display_errors off
php_flag log_errors on

# Session security
php_value session.cookie_httponly 1
php_value session.use_strict_mode 1
php_value session.gc_maxlifetime 3600
php_value session.cookie_samesite "Strict"

# Block bad bots and scanners
<IfModule mod_rewrite.c>
  RewriteCond %{HTTP_USER_AGENT} (sqlmap|nikto|nmap|masscan|dirbuster|gobuster|ZAP|nessus) [NC]
  RewriteRule .* - [F,L]
</IfModule>

# Limit POST body size (2MB max)
LimitRequestBody 2097152
